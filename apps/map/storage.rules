rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /generator-photos/{photo} {
      // Only authenticated users may read or write generator photos.
      // Writes are further restricted to files under 20 MB (20 * 1024 * 1024 bytes)
      // and to the allowed image MIME types used by the application.
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size <= 20 * 1024 * 1024
        && request.resource.contentType.matches('image/(jpeg|png|webp|gif)');
    }
  }
}
