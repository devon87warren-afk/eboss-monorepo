# Salesforce Credentials
SF_USERNAME=your.email@company.com
SF_PASSWORD=YourPassword123
SF_TOKEN=YourSecurityToken123

# Your Salesforce User ID (18-character ID starting with 005)
# Find this by: Setup → Users → Click your name → View URL
SF_NEW_OWNER_ID=005XXXXXXXXXXXXXXX

# Territory ID where contacts are located
# This could be a custom field value on Contact object
SF_TERRITORY_ID=YOUR_TERRITORY_NAME_OR_ID

# Set to 'true' if using Salesforce Sandbox
SF_SANDBOX=false
