# EBOSS Manager Environment Configuration
# Copy this file to .env and fill in your actual values

# ============================================
# Microsoft Outlook Integration (Azure AD)
# ============================================
# Get these from Azure Portal → App Registrations → Your App

# Application (client) ID from Azure AD
VITE_OUTLOOK_CLIENT_ID=your_application_client_id_here

# Client Secret (the value you copied from Certificates & Secrets)
VITE_OUTLOOK_CLIENT_SECRET=your_client_secret_value_here

# OAuth Redirect URI (must match Azure AD app registration)
# For local development: http://localhost:3000
# For production: https://yourdomain.com
VITE_OUTLOOK_REDIRECT_URI=http://localhost:3000

# ============================================
# Salesforce Integration
# ============================================
# Get these from Salesforce Setup → Apps → App Manager → Your Connected App

# Consumer Key (Client ID)
VITE_SF_CLIENT_ID=your_salesforce_consumer_key

# Consumer Secret (Client Secret)
VITE_SF_CLIENT_SECRET=your_salesforce_consumer_secret

# OAuth Callback URL
VITE_SF_REDIRECT_URI=http://localhost:3000/sf-callback

# Set to 'true' for Salesforce Sandbox, 'false' for Production
VITE_SF_SANDBOX=false

# ============================================
# Supabase Configuration
# ============================================
# Get these from your Supabase project settings

VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# ============================================
# Google Gemini AI (Optional)
# ============================================
# Used for AI-powered ticket analysis

GEMINI_API_KEY=your_gemini_api_key

# ============================================
# Application Settings
# ============================================

# Environment: development, staging, production
NODE_ENV=development

# Application Port
PORT=3000
# ====================
# EBOSS Manager - Environment Variables Template
# ====================
# Copy this file to .env.local and fill in your actual values

# --------------------
# Gemini AI (Google AI Studio)
# --------------------
# Get your API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# --------------------
# Supabase (Primary Database)
# --------------------
# Get these from: https://supabase.com/dashboard/project/_/settings/api
# REQUIRED for real backend functionality
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# --------------------
# Salesforce OAuth (Optional)
# --------------------
# For Salesforce CRM integration
# Get credentials from: Salesforce Setup > Apps > App Manager > Create Connected App
VITE_SF_CLIENT_ID=your_salesforce_client_id
VITE_SF_CLIENT_SECRET=your_salesforce_client_secret
VITE_SF_REDIRECT_URI=http://localhost:3000/sf-callback
VITE_SF_SANDBOX=false  # Set to 'true' for sandbox environment

# --------------------
# Outlook OAuth (Optional)
# --------------------
# For Microsoft Outlook email integration
# Get credentials from: Azure Portal > App Registrations
VITE_OUTLOOK_CLIENT_ID=your_outlook_client_id
VITE_OUTLOOK_CLIENT_SECRET=your_outlook_client_secret
VITE_OUTLOOK_REDIRECT_URI=http://localhost:3000/outlook-callback

# --------------------
# Builder.io (Optional)
# --------------------
# For visual page building
VITE_BUILDER_API_KEY=your_builder_io_key
