# ── Linear ──────────────────────────────────────────────────────────────────
# Signing secret from Linear Settings → API → Webhooks → your webhook → Secret
LINEAR_WEBHOOK_SECRET=

# ── OpenClaw gateway ─────────────────────────────────────────────────────────
# Same token as in .openclaw/openclaw.json  (generate: openssl rand -hex 32)
OPENCLAW_GATEWAY_TOKEN=

# WhatsApp recipient in E.164 format, e.g. +19995550123
OPENCLAW_WHATSAPP_TO=

# Only change these if OpenClaw is not on localhost:18789
OPENCLAW_HOST=127.0.0.1
OPENCLAW_PORT=18789

# ── GitHub ───────────────────────────────────────────────────────────────────
# Used to construct PR URLs in the prompt, e.g. "org/repo"
GITHUB_REPO=

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3000
